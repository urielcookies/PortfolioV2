---
import { SocialIcons } from "../ui/social-icons";

const IS_DEV = import.meta.env.DEV;

const POST_URL = IS_DEV
  ? 'http://127.0.0.1:5001/portfoliocontactform'
  : 'https://everscode-api.up.railway.app/portfoliocontactform';
---
<section id="contact" class="section contact-section">
  <div class="container">
    <h2 class="contact-title text-3xl md:text-4xl font-bold mb-8 text-center text-teal-400">Contact Me</h2>
    <div class="social-row">
      <SocialIcons client:load />
    </div>

    <div id="form-response">
      <!-- Removed action="https://formspree.io/uriel621@live.com" -->
      <form
        id="contact-form"
        class="contact-form"
        novalidate
        method="post"
        hx-post={POST_URL}
        hx-target="#form-response"
        hx-swap="outerHTML">
        <div class="input-row">
          <div class="input-group">
            <input type="text" id="first-name" name="firstName" placeholder=" " required />
            <label for="first-name">First Name</label>
          </div>
          <div class="input-group">
            <input type="text" id="last-name" name="lastName" placeholder=" " required />
            <label for="last-name">Last Name</label>
          </div>
        </div>

        <div class="input-row">
          <div class="input-group">
            <input type="tel" id="phone" name="phone" placeholder=" " pattern="^\+?[0-9\s\-]{7,15}$" />
            <label for="phone">Phone</label>
          </div>
          <div class="input-group">
            <input type="email" id="email" name="email" placeholder=" " required />
            <label for="email">Email</label>
          </div>
        </div>

        <div class="input-group full-width">
          <textarea id="message" name="message" rows="5" placeholder=" " required></textarea>
          <label for="message">Message</label>
        </div>

        <input type="text" name="website" id="website" style="display:none" autocomplete="off" />

        <button type="submit" class="btn-submit">Send Message</button>
      </form>
    </div>
  </div>
</section>

<style>
  #contact {
    height: 90vh;
    scroll-margin-top: 10vh;
  }

  .contact-section {
    background-color: var(--color-bg);
    color: var(--color-text);
    padding: 5rem 2rem;
  }

  .container {
    max-width: 700px;
    margin: 0 auto;
  }

  .contact-title {
    font-size: 2.75rem;
    font-weight: 700;
    margin-bottom: 3rem;
    text-align: center;
    color: var(--color-highlight);
  }

  form.contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .input-row {
    display: flex;
    gap: 1.5rem;
  }

  @media (max-width: 600px) {
    .input-row {
      flex-direction: column;
    }

    #contact {
      height: auto;
    }

    .contact-title {
      font-size: 1.75rem;
      margin-bottom: 1rem;
    }

    #contact {
      height: auto;
    }
  }

  .input-group {
    flex: 1;
    position: relative;
  }

  .input-group.full-width {
    flex: 1 1 100%;
  }

  input[type="text"],
  input[type="tel"],
  input[type="email"],
  textarea {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1.5px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.625rem;
    padding: 1.5rem 1rem 0.5rem;
    color: var(--color-text);
    font-size: 0.95rem;
    width: 100%;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  textarea {
    resize: vertical;
    min-height: 120px;
    padding-top: 1.75rem;
  }

  /* Floating label — default state (inside the field) */
  .input-group label {
    position: absolute;
    left: 1rem;
    top: 1rem;
    font-size: 0.9rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.35);
    pointer-events: none;
    transition: all 0.18s ease;
    margin: 0;
  }

  /* Textarea label starts a bit higher */
  .input-group textarea ~ label {
    top: 1.1rem;
  }

  /* Floated state — on focus or when filled */
  .input-group input:focus ~ label,
  .input-group input:not(:placeholder-shown) ~ label,
  .input-group textarea:focus ~ label,
  .input-group textarea:not(:placeholder-shown) ~ label {
    top: 0.35rem;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-highlight);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-highlight);
    background-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 0 0 3px rgba(79, 191, 168, 0.15);
  }

  .btn-submit {
    align-self: center;
    background-color: var(--color-highlight);
    color: white;
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0.9rem 2.5rem;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background-color 0.3s ease;
    box-shadow: 0 6px 12px rgba(79, 191, 168, 0.5);
  }

  .btn-submit:hover {
    background-color: var(--color-highlight-hover);
    box-shadow: 0 8px 16px rgba(62, 167, 144, 0.7);
  }

  .social-row {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', function (e) {
      const honeypot = (document.getElementById('website') as HTMLInputElement)?.value;
      if (honeypot) {
        e.preventDefault();
        console.warn('Bot detected - submission blocked.');
        return;
      }
    });
  }
</script>
