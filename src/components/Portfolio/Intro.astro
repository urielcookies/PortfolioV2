<section id="intro" class="intro">
  <div id="tsparticles-intro" class="particles-bg"></div>
  <div class="intro-content">
    <h1>
      Hi, I'm <span class="highlight">Ever Uriel Garcia</span><br />
      A FullStack Web Developer
    </h1>
    <p>
      I build fullstack applications from the ground up.
      When I'm not coding at work,
      I'm working on personal projects, contributing to open source
      (<a href="http://www.hackforla.org/" id="hack4la" target="_blank" rel="noopener noreferrer">Hack for LA</a>),
      or watching the latest Fireship videos on YouTube—sometimes all at once. I love what I do.
    </p>
    <a href="#contact" class="btn">Let's Work Together</a>
  </div>
</section>

<style>
  .intro {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 10vh;
    height: 90vh;
    scroll-margin-top: 10vh;
    background-color: var(--color-bg);
    color: var(--color-text);
    text-align: center;
    padding: 6rem 1.5rem;
    overflow: hidden;
  }

  .particles-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .intro-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .intro-content.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .intro h1 {
    font-size: 2.75rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .highlight {
    color: var(--color-highlight);
  }

  .intro p {
    font-size: 1.15rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    color: var(--color-text);
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-highlight);
    color: #000;
    border-radius: 0.375rem;
    text-decoration: none;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .btn:hover {
    background-color: #3aa98e;
  }

  #hack4la {
    color: #fa114f;
  }

  @media (max-width: 768px) {
    .intro h1 {
      font-size: 2rem;
    }

    .intro p {
      font-size: 1rem;
    }
  }
</style>

<script>
  import { tsParticles } from "@tsparticles/engine";
  import { loadSlim } from "@tsparticles/slim";

  await loadSlim(tsParticles);

  await tsParticles.load({
    id: "tsparticles-intro",
    options: {
      fullScreen: { enable: false },
      fpsLimit: 120,
      particles: {
        color: { value: "#14b8a6" },
        move: {
          enable: true,
          direction: "none",
          outModes: { default: "out" },
          speed: { min: 0.1, max: 1 },
        },
        number: {
          density: { enable: true, width: 400, height: 400 },
          value: 100,
        },
        opacity: {
          value: { min: 0.1, max: 1 },
          animation: {
            enable: true,
            speed: 1,
            sync: false,
          },
        },
        shape: { type: "circle" },
        size: {
          value: { min: 0.6, max: 1.4 },
        },
      },
      detectRetina: true,
    },
  });

  const introContent = document.querySelector('.intro-content');
  if (introContent) {
    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            introContent.classList.add('visible');
            obs.unobserve(introContent);
          }
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(introContent);
  }
</script>
